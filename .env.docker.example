# Copia este archivo a ".env" (misma carpeta que docker-compose.yml) y edítalo.
# NO subas el archivo .env real a ningún repositorio.

# Credenciales del panel de administración (/admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIA_ESTA_CLAVE
# Token que protege las rutas de subida/borrado (genera uno aleatorio largo)
ADMIN_TOKEN=CAMBIA_ESTE_TOKEN

# Puerto público en el servidor:  http://IP-DEL-SERVIDOR:HOST_PORT
HOST_PORT=8080

# false = se sirve por HTTP interno (la sesión funciona sin HTTPS)
# true  = solo si hay HTTPS delante (proxy/balanceador con certificado)
COOKIE_SECURE=false
