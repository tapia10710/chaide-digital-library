# Copia este archivo a ".env" (misma carpeta que docker-compose.yml) y editalo.
# NO subas el archivo .env real a ningun repositorio.

# Credenciales del panel de administracion (/admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIA_ESTA_CLAVE

# Token que protege las rutas de subida y borrado. Usa un valor aleatorio largo.
ADMIN_TOKEN=CAMBIA_ESTE_TOKEN

# Puerto publico: http://IP-DEL-SERVIDOR:HOST_PORT
HOST_PORT=8080

# false: HTTP interno.
# true: solamente cuando exista HTTPS delante del servicio.
COOKIE_SECURE=false
