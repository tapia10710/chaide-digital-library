# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GCS_BUCKET_NAME: Needed for Google Cloud Storage integration.
GCS_BUCKET_NAME="YOUR_BUCKET_NAME"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Required to enable write/admin API endpoints. Keep this value server-side.
ADMIN_TOKEN="CHANGE_ME"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CHANGE_ME"

# Hosting providers set PORT automatically.
PORT="3000"

# Railway persistent volume mount.
DATA_DIR="/data"
