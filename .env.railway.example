# Copiar estos nombres en Railway > Service > Variables.
# No subir valores reales al repositorio.

NODE_ENV=production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIA_ESTA_CLAVE
ADMIN_TOKEN=CAMBIA_ESTE_TOKEN_LARGO_Y_ALEATORIO
COOKIE_SECURE=true

# Al conectar un volumen, Railway crea RAILWAY_VOLUME_MOUNT_PATH.
# DATA_DIR no es necesario si el volumen esta conectado correctamente.
